
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow read access to all files
    match /{allPaths=**} {
      allow read;
    }

    // Allow authenticated users to write to the 'group-avatars' and 'chat-attachments' directories
    match /group-avatars/{allPaths=**} {
      allow write: if request.auth != null;
    }
    match /chat-attachments/{allPaths=**} {
      allow write: if request.auth != null;
    }
  }
}
