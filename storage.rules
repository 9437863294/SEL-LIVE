
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Allow read access to all files by default
    match /{allPaths=**} {
      allow read;
    }
    
    // Allow authenticated users to write to their own profile photo folder
    match /profile-photos/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow authenticated users to write to chat attachments
    match /chat-attachments/{chatId}/{fileName} {
      allow write: if request.auth != null;
    }

    // Allow authenticated users to write to requisitions folder
    match /requisitions/{requisitionId}/{fileName} {
        allow write: if request.auth != null;
    }

    // Allow authenticated users to write to daily requisitions folder
    match /daily-requisitions/{receptionNo}/{fileName} {
        allow write: if request.auth != null;
    }

    // Allow authenticated users to write to the group-avatars folder
    match /group-avatars/{chatId}/{fileName} {
      allow write: if request.auth != null;
    }
  }
}
