rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow read access to all files for authenticated users
    match /{allPaths=**} {
      allow read: if request.auth != null;
    }

    // Allow write access only to the daily-requisitions path for authenticated users
    match /daily-requisitions/{allPaths=**} {
      allow write: if request.auth != null;
    }
  }
}
